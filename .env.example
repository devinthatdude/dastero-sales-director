# Copy this file to .env and fill in values from Supabase → Connect dialog.
# Both are safe to expose in the browser — security is enforced by RLS, not by hiding these.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# Google Maps prospecting (Today tab). Browser key by design, BUT restrict it by
# HTTP referrer to your domains in Google Cloud, and enable: Maps JavaScript API
# + Places API (billing on). The Today map shows a setup card until this is set.
VITE_GOOGLE_MAPS_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxx
